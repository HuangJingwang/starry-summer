{
  "name": "starry-summer",
  "private": true,
  "version": "0.1.0",
  "description": "Personal content platform for writing, notes, moments, projects, and reader interaction.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @starry-summer/web",
    "dev:web": "npm run dev --workspace @starry-summer/web",
    "dev:api": "npm run start:dev --workspace @starry-summer/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
