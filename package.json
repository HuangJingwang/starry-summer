{
  "name": "starry-summer",
  "private": true,
  "version": "0.1.0",
  "description": "Personal content platform for writing, notes, moments, projects, and reader interaction.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @starry-summer/web",
    "dev:web": "npm run dev --workspace @starry-summer/web",
    "dev:api": "npm run start:dev --workspace @starry-summer/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && npm run test:ops",
    "test:ops": "bash scripts/smoke.test.sh && bash scripts/backup.test.sh && bash scripts/restore.test.sh && bash scripts/dockerfile.test.sh && bash scripts/docker-preflight.test.sh && bash scripts/init-env.test.sh && bash scripts/deploy.test.sh",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "auth:hash-password": "npm run hash-password --workspace @starry-summer/api",
    "auth:interaction-secret": "npm run interaction-secret --workspace @starry-summer/api",
    "auth:secret": "npm run session-secret --workspace @starry-summer/api",
    "db:migrate": "npm run migrate --workspace @starry-summer/database",
    "ops:backup": "bash scripts/backup.sh",
    "ops:restore": "bash scripts/restore.sh",
    "ops:doctor": "bash scripts/doctor.sh",
    "ops:docker-preflight": "bash scripts/docker-preflight.sh",
    "ops:init-env": "bash scripts/init-env.sh",
    "ops:smoke": "bash scripts/smoke.sh",
    "ops:deploy": "bash scripts/deploy.sh"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
