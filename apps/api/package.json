{
  "name": "@starry-summer/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "hash-password": "tsx src/auth/hash-password.ts",
    "interaction-secret": "tsx src/auth/interaction-secret.ts",
    "session-secret": "tsx src/auth/session-secret.ts",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "tsx watch src/main.ts",
    "test": "vitest run --pool=forks",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@starry-summer/markdown": "file:../../packages/markdown",
    "@starry-summer/shared": "file:../../packages/shared",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.16.3",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
