# Runtime
NODE_ENV=production
PUBLIC_SITE_URL=http://localhost
API_BASE_URL=http://api:4000
RELEASE_VERSION=development
GIT_REVISION=unknown

# Admin
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD_HASH=replace-with-scrypt-hash
SESSION_SECRET=replace-with-long-random-secret
INTERACTION_HASH_SECRET=replace-with-long-random-interaction-secret

# Database
POSTGRES_DB=starry_summer
POSTGRES_USER=starry
POSTGRES_PASSWORD=starry
DATABASE_URL=postgresql://starry:starry@postgres:5432/starry_summer
CONTENT_REPOSITORY_DRIVER=postgres
REDIS_URL=redis://redis:6379

# Object storage
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=/app/uploads
LOCAL_UPLOAD_PUBLIC_URL=/uploads
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=starry-summer
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/starry-summer
S3_FORCE_PATH_STYLE=true

# Reverse proxy / deployment
DOMAIN=localhost
ACME_EMAIL=owner@example.com
