{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/post-git-push-check.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking post-push deployment status"
          }
        ]
      }
    ]
  }
}
